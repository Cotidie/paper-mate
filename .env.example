# Copy to .env to override. Both are optional.
# Host port the app is published on (container always listens on 8000).
PAPER_MATE_PORT=8000
# Host data dir mounted to /data (storage root). Defaults to ~/.paper-mate.
PAPER_MATE_DATA=${HOME}/.paper-mate
# Host user/group the container runs as, so files in /data are host-owned and
# editable/deletable from the host (not root:root). Defaults to 1000:1000.
# Override if your host uid/gid differ (check with "id -u" / "id -g").
PAPER_MATE_UID=1000
PAPER_MATE_GID=1000
